# Get your FREE Groq API key at: https://console.groq.com
# No daily limits, no credit card needed
GROQ_API_KEY=your_api_key_here

# These defaults match docker-compose.yml — change only if needed for local development
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=thinkmap123
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- 100% Free Cloud Deployment Settings ---
# If deploying to the cloud, use these instead of the local endpoints above:
# NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_aura_password
# QDRANT_URL=https://your-cluster.us-east4-0.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=your_qdrant_api_key
